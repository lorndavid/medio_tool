<div class="space-y-6 fade-in">
  <h1 class="text-2xl font-semibold tracking-tight">Bot settings</h1>

  <form method="post" action="/admin/settings" class="glass p-6 space-y-5 max-w-3xl">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <label class="flex items-center gap-3">
        <input type="checkbox" name="maintenance" <%= settings.maintenance ? 'checked' : '' %> />
        <span>Maintenance mode</span>
      </label>
      <div>
        <label class="label">Default language</label>
        <select class="select" name="defaultLanguage">
          <% ['en','km','pl','ko'].forEach(l => { %>
            <option value="<%= l %>" <%= settings.defaultLanguage === l ? 'selected' : '' %>><%= l %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div>
      <label class="label">Maintenance message</label>
      <textarea class="textarea" name="maintenanceMessage" rows="2"><%= settings.maintenanceMessage %></textarea>
    </div>

    <div>
      <div class="label">Enabled platforms</div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
        <% ['tiktok','instagram','facebook','youtube'].forEach(p => { %>
          <label class="flex items-center gap-2 px-3 py-2 rounded-lg bg-white/5 border border-white/5">
            <input type="checkbox" name="platforms.<%= p %>" <%= settings.enabledPlatforms?.[p] ? 'checked' : '' %> />
            <span class="capitalize"><%= p %></span>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="label">Per-user rate limit (per minute)</label>
        <input class="input" name="perUserPerMinute" type="number" min="1" value="<%= settings.rateLimits?.perUserPerMinute || 10 %>" />
      </div>
    </div>

    <div class="flex justify-end">
      <button class="btn">Save settings</button>
    </div>
  </form>
</div>
