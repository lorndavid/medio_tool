<aside class="w-64 hidden md:flex flex-col bg-slate-900/70 backdrop-blur-xl border-r border-white/5 sticky top-0 h-screen">
  <div class="px-6 py-5 border-b border-white/5">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-sky-400 to-indigo-600 grid place-items-center shadow-lg">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
      </div>
      <div>
        <div class="font-semibold tracking-tight">MediaFlow</div>
        <div class="text-xs text-slate-400">Admin Console</div>
      </div>
    </div>
  </div>
  <nav class="flex-1 px-3 py-4 space-y-1 text-sm">
    <% const items = [
      { key:'overview', href:'/admin', label:'Overview', icon:'home' },
      { key:'users', href:'/admin/users', label:'Users', icon:'users' },
      { key:'analytics', href:'/admin/analytics', label:'Analytics', icon:'chart' },
      { key:'media', href:'/admin/media', label:'Media activity', icon:'media' },
      { key:'logs', href:'/admin/logs', label:'System logs', icon:'logs' },
      { key:'languages', href:'/admin/languages', label:'Languages', icon:'lang' },
      { key:'settings', href:'/admin/settings', label:'Bot settings', icon:'gear' },
      { key:'broadcast', href:'/admin/broadcast', label:'Broadcast', icon:'megaphone' },
      { key:'support', href:'/admin/support', label:'Support', icon:'support' },
      { key:'api', href:'/admin/api-settings', label:'API settings', icon:'api' },
      { key:'themes', href:'/admin/themes', label:'Themes', icon:'palette' },
      { key:'performance', href:'/admin/performance', label:'Performance', icon:'pulse' },
    ]; %>
    <% items.forEach(item => { %>
      <a href="<%= item.href %>"
         class="nav-link <%= page === item.key ? 'nav-link--active' : '' %>">
        <span class="w-2 h-2 rounded-full <%= page === item.key ? 'bg-sky-400' : 'bg-slate-600' %>"></span>
        <span><%= item.label %></span>
      </a>
    <% }) %>
  </nav>
  <div class="p-4 border-t border-white/5">
    <div class="text-xs text-slate-400 mb-2">Signed in as</div>
    <div class="text-sm font-medium truncate"><%= adminName %></div>
    <form method="post" action="/admin/logout" class="mt-3">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
      <button class="btn-outline w-full text-xs">Logout</button>
    </form>
  </div>
</aside>
