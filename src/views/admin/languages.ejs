<div class="space-y-5 fade-in">
  <h1 class="text-2xl font-semibold tracking-tight">Languages</h1>
  <p class="text-slate-400 text-sm">Translation files live in <code>src/locales/*.json</code>. Edit them directly to change bot copy.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <% [
      { code:'en', name:'English', flag:'🇬🇧' },
      { code:'km', name:'Khmer · ខ្មែរ', flag:'🇰🇭' },
      { code:'pl', name:'Polski', flag:'🇵🇱' },
      { code:'ko', name:'한국어', flag:'🇰🇷' },
    ].forEach(l => { %>
      <div class="glass p-5">
        <div class="text-3xl"><%= l.flag %></div>
        <div class="mt-2 font-semibold"><%= l.name %></div>
        <div class="text-xs text-slate-400"><%= l.code %>.json</div>
      </div>
    <% }) %>
  </div>
</div>
