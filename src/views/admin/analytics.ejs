<div class="space-y-6 fade-in">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Analytics</h1>
    <p class="text-slate-400 text-sm">Last 14 days</p>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="glass p-5">
      <h2 class="font-semibold mb-3">Activity (events / day)</h2>
      <canvas data-chart-line height="220"
        data-labels='<%- JSON.stringify(byDay.labels) %>'
        data-values='<%- JSON.stringify(byDay.values) %>'></canvas>
    </div>
    <div class="glass p-5">
      <h2 class="font-semibold mb-3">By platform</h2>
      <canvas data-chart-bar height="220"
        data-labels='<%- JSON.stringify(byPlatform.labels) %>'
        data-values='<%- JSON.stringify(byPlatform.values) %>'></canvas>
    </div>
  </div>
  <div class="glass p-5">
    <h2 class="font-semibold mb-3">Event types (lifetime)</h2>
    <table class="table">
      <thead><tr><th>Type</th><th>Count</th></tr></thead>
      <tbody>
        <% byType.forEach(t => { %>
          <tr><td><%= t._id %></td><td><%= t.count.toLocaleString() %></td></tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
