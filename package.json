{
  "name": "mediaflow-bot",
  "version": "1.0.0",
  "description": "MediaFlow Bot — production-grade Telegram media assistant + admin dashboard. Optimized for Oracle Cloud Free Tier and Cambodia mobile networks.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/queues/worker.js",
    "lint": "echo \"add eslint if desired\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:save": "pm2 save",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "reset:admin": "node src/scripts/resetAdmin.js",
    "test:mongo": "node src/scripts/testMongo.js",
    "set:mongo": "node src/scripts/setMongo.js",
    "test:telegram": "node src/scripts/testTelegram.js",
    "set:telegram": "node src/scripts/setTelegram.js",
    "build:css": "tailwindcss -i src/styles/tailwind.input.css -o public/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i src/styles/tailwind.input.css -o public/css/tailwind.css --watch"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.3",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "node-telegram-bot-api": "^0.66.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "telegram",
    "bot",
    "tiktok",
    "instagram",
    "youtube",
    "media",
    "downloader",
    "cambodia",
    "oracle"
  ],
  "author": "MediaFlow",
  "license": "MIT"
}
