# ============================================================
# MediaFlow Bot — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
APP_NAME=MediaFlow Bot
PUBLIC_URL=http://localhost:3000

# --- Telegram ---
TELEGRAM_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_DOMAIN=
# If TELEGRAM_WEBHOOK_DOMAIN is empty, bot uses long polling (good for dev)
# In production set it to your HTTPS domain, e.g. https://bot.example.com

# --- MongoDB Atlas (SRV) ---
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/mediaflow?retryWrites=true&w=majority

# --- Redis (optional, used for BullMQ queue + caching) ---
# Set REDIS_ENABLED=false to disable queue (lightweight mode for tiny servers).
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT / Sessions ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace_with_another_long_random_string

# --- Admin bootstrap (used by `npm run seed:admin`) ---
ADMIN_EMAIL=admin@mediaflow.local
ADMIN_PASSWORD=ChangeMe!2026
ADMIN_NAME=Super Admin

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# --- Logging ---
LOG_LEVEL=info

# --- Optional API keys ---
TIKWM_API=https://tikwm.com/api/
